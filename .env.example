# OpenAI API key (only required when llm.provider = "openai")
OPENAI_API_KEY=

# Optional override of the OpenAI base URL (any OpenAI-compatible endpoint)
# OPENAI_BASE_URL=

# DeepSeek API key (only required when llm.provider = "deepseek")
# Get one at https://platform.deepseek.com/
# DEEPSEEK_API_KEY=
# Optional override (defaults to https://api.deepseek.com)
# DEEPSEEK_BASE_URL=

# Optional Semantic Scholar API key (lifts the public ~1 RPS rate limit).
# Without it, enrichment still works — just slower.
# SEMANTIC_SCHOLAR_API_KEY=

# Logging level
LOG_LEVEL=INFO

# ───────────────────────────────────────────────────────────
# Project: runtime data artifacts
# Keep data/ checked in (with .gitkeep) but ignore everything inside it,
# plus user-resolved configs that are derived from *.example.yaml.
# ───────────────────────────────────────────────────────────
data/*
!data/.gitkeep

configs/runtime.yaml
configs/sources.yaml
configs/research_profile.yaml

